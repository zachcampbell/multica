# Multica daemon environment — loaded by systemd via EnvironmentFile.
# Copy to ~/.config/multica/daemon.env and edit.

# PATH must include agent CLIs (claude, codex, etc.) that may live outside
# systemd's default PATH (e.g. nvm-managed node, cargo bins, etc.)
# PATH=/home/you/.nvm/versions/node/v22.18.0/bin:/home/you/.local/bin:/usr/local/bin:/usr/bin:/bin

# Server connection
DATABASE_URL=postgres://multica:multica@localhost:5433/multica?sslmode=disable
JWT_SECRET=multica-local-dev-secret-2026
MULTICA_SERVER_URL=ws://localhost:8080/ws
MULTICA_APP_URL=http://localhost:3000

# Ollama/LiteLLM proxy (remove if not using Ollama)
MULTICA_OLLAMA_HOST=
MULTICA_OLLAMA_API_KEY=
MULTICA_OLLAMA_MODEL=kimi-k2.5

# Optional overrides
# MULTICA_DAEMON_ID=
# MULTICA_DAEMON_DEVICE_NAME=
# MULTICA_DAEMON_POLL_INTERVAL=3s
# MULTICA_DAEMON_HEARTBEAT_INTERVAL=15s
